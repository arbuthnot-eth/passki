{
  "name": "passki",
  "version": "0.1.8",
  "description": "passki — Sui-native sign-in, once, everywhere.",
  "type": "module",
  "main": "public/dist/ski.js",
  "module": "public/dist/ski.js",
  "exports": {
    ".": "./public/dist/ski.js",
    "./embed": "./public/dist/embed.js",
    "./styles": "./public/styles.css",
    "./assets/*": "./public/assets/*"
  },
  "files": [
    "public/dist",
    "public/styles.css",
    "public/assets",
    "public/index.html",
    "src",
    "README.md"
  ],
  "keywords": [
    "sui",
    "wallet",
    "web3",
    "sign-in",
    "suins",
    "wallet-standard",
    "dapp",
    "cloudflare-workers"
  ],
  "license": "MIT",
  "homepage": "https://passki.xyz",
  "repository": {
    "type": "git",
    "url": "https://github.com/arbuthnot-eth/passki"
  },
  "scripts": {
    "build": "rm -rf public/dist && bun build src/ski.ts --outdir public/dist --target browser --minify --format esm --loader .svg:text && bun build src/embed.ts --outfile public/dist/embed.js --target browser --minify --format iife && bun build src/encrypt-demo.ts --outfile public/dist/encrypt-demo.js --target browser --minify --format esm && cp node_modules/@ika.xyz/ika-wasm/dist/web/dwallet_mpc_wasm_bg.wasm public/dist/ && cp node_modules/@mysten/walrus-wasm/web/walrus_wasm_bg.wasm public/dist/",
    "dev": "bun build src/ski.ts --outdir public/dist --target browser --watch --splitting --format esm --loader .svg:text",
    "dev:wrangler": "wrangler dev",
    "dev:devnet": "wrangler dev --config wrangler.devnet.jsonc",
    "deploy:devnet": "bun run build && npx wrangler deploy --config wrangler.devnet.jsonc",
    "deploy": "bun update && bun run build && npx wrangler deploy",
    "smoke": "node scripts/devnet-smoke.mjs",
    "squids": "bun scripts/squids.ts",
    "check:move": "bun scripts/check-move-targets.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "bun run build"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260417.1",
    "@types/qrcode": "^1.5.6",
    "playwright": "^1.59.1",
    "typescript": "^6.0.3",
    "wrangler": "^4.83.0"
  },
  "dependencies": {
    "@fingerprintjs/fingerprintjs": "^5.2.0",
    "@human.tech/waap-sdk": "1.3.0",
    "@ika.xyz/sdk": "0.3.1",
    "@mysten/dapp-kit-core": "^1.3.0",
    "@mysten/kiosk": "^1.2.2",
    "@mysten/seal": "^1.1.1",
    "@mysten/sui": "^2.16.0",
    "@mysten/sui-groups": "^0.0.1",
    "@mysten/sui-stack-messaging": "^0.0.2",
    "@mysten/suins": "^1.0.5",
    "@mysten/walrus": "^1.1.2",
    "@noble/curves": "^2.2.0",
    "@noble/hashes": "^2.2.0",
    "@scure/base": "^2.0.0",
    "@wallet-standard/app": "^1.1.0",
    "aftermath-ts-sdk": "^2.0.0",
    "agents": "^0.10.2",
    "hono": "^4.12.14",
    "hono-agents": "^3.0.10",
    "qrcode": "^1.5.4",
    "suiami": "2.0.0",
    "viem": "^2.48.1"
  }
}
