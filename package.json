{
  "name": "sui.ski",
  "version": "1.0.6",
  "description": ".SKI — One-button Sui wallet sign-in. Connect once, authenticate everywhere.",
  "type": "module",
  "main": "public/dist/ski.js",
  "module": "public/dist/ski.js",
  "exports": {
    ".": "./public/dist/ski.js",
    "./styles": "./public/styles.css",
    "./assets/*": "./public/assets/*"
  },
  "files": [
    "public/dist",
    "public/styles.css",
    "public/assets",
    "public/index.html",
    "src",
    "README.md"
  ],
  "keywords": [
    "sui",
    "wallet",
    "web3",
    "sign-in",
    "suins",
    "wallet-standard",
    "dapp",
    "cloudflare-workers"
  ],
  "license": "MIT",
  "homepage": "https://sui.ski",
  "repository": {
    "type": "git",
    "url": "https://github.com/arbuthnot-eth/.SKI"
  },
  "scripts": {
    "build": "rm -rf public/dist && bun build src/ski.ts --outdir public/dist --target browser --minify --splitting --format esm --loader .svg:text",
    "dev": "bun build src/ski.ts --outdir public/dist --target browser --watch --splitting --format esm --loader .svg:text",
    "dev:wrangler": "wrangler dev",
    "deploy": "bun update && bun run build && npx wrangler deploy",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "bun run build"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260317.1",
    "@types/qrcode": "^1.5.6",
    "potrace": "^2.1.8",
    "typescript": "^5.9.3",
    "wrangler": "^4.77.0"
  },
  "dependencies": {
    "@7kprotocol/sdk-ts": "^4.0.0",
    "@fingerprintjs/fingerprintjs": "^5.1.0",
    "@human.tech/waap-sdk": "^1.2.2",
    "@ika.xyz/sdk": "^0.2.7",
    "@mysten/dapp-kit-core": "^1.2.0",
    "@mysten/deepbook-v3": "^1.2.1",
    "@mysten/kiosk": "^1.1.3",
    "@mysten/seal": "^1.1.1",
    "@mysten/sui": "^2.11.0",
    "@mysten/suins": "^1.0.2",
    "@mysten/wallet-standard": "^0.20.1",
    "@pythnetwork/pyth-sui-js": "^3.0.0",
    "@wallet-standard/app": "^1.1.0",
    "agents": "^0.6.0",
    "hono": "^4.12.9",
    "hono-agents": "^3.0.7",
    "kumo-ui": "^0.2.1",
    "qrcode": "^1.5.4"
  }
}
