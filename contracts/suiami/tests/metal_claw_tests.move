    // Init + set_identity with ONLY a btc chain, no "eth" entry.
    roster::init_for_testing(ts::ctx(&mut scenario));
    ts::next_tx(&mut scenario, TEST_SENDER);

    let mut r = ts::take_shared<Roster>(&mut scenario);
    let chain_keys = vector[string::utf8(b"btc")];
    let chain_values = vector[string::utf8(b"bc1qexampleonly")];
    roster::set_identity(
        &mut r,
        string::utf8(b"alice"),
        test_ens_hash(),
        chain_keys,
        chain_values,
        vector::empty<address>(),
        string::utf8(b""),
        vector::empty<u8>(),
        &clk,
        ts::ctx(&mut scenario),
    );
    ts::return_shared(r);
    ts::next_tx(&mut scenario, TEST_SENDER);

    let mut r2 = ts::take_shared<Roster>(&mut scenario);
    roster::set_ens_identity_verified(
        &mut r2,
        string::utf8(TEST_ENS_NAME_BYTES),
        test_ens_hash(),
        TEST_SIG,
        TEST_TS_MS,
        &clk,
        ts::ctx(&mut scenario),
    );
    ts::return_shared(r2);

    clock::destroy_for_testing(clk);
    ts::end(scenario);
}
